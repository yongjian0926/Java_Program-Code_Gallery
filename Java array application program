package average;
import java.util.Scanner;
public class average {
	public static void main(String[] average) {
		Scanner sc = new Scanner(System.in);
		System.out.print("请输入学生人数：");
		int count = sc.nextInt();
		double scores[] = new double[count];
		double totalScore = 0;
		for(int i=0; i<count; i++) {
			System.out.print("请输入第" + (i+1) +"名同学的成绩:");
			scores [i] = sc.nextDouble();
			totalScore+= scores[i];
		}
		double averageScore = totalScore / count;
		String sumStr = String.format("%.2f",totalScore);
		String avgStr = String.format("%.2f",averageScore);
		System.out.println(count + "名学生的总成绩是：" + sumStr+ "分.");
		System.out.println(count + "名学生的平均分是："+ avgStr + "分。" );
	}
}
