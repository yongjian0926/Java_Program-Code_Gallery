package if_else;
import java.util.Scanner;
public class Switch {
	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		System.out.print("请输入数值：");
		int i = sc.nextInt();
		switch(i) {
		case 1:
			System.out.print("1月份");
			break;
		case 2:
			System.out.print("2月份");
			break;
		case 3:
			System.out.print("3月份");
			break;
		case 4:
			System.out.print("4月份");
			break;
		case 5:
			System.out.print("5月份");
			break;
		case 6:
			System.out.print("6月份");
			break;
		case 7:
			System.out.print("7月份");
			break;
		case 8:
			System.out.print("8月份");
			break;
		case 9:
			System.out.print("9月份");
			break;
		case 10:
			System.out.print("10月份");
			break;
		case 11:
			System.out.print("11月份");
			break;
		case 12:
			System.out.print("12月份");
			break;
		default:
			System.out.println("数值错误");
		}
	}
}
